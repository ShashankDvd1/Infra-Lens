# LandScope AI — Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://landscape:landscape@db:5432/landscape_ai
DATABASE_URL_SYNC=postgresql://landscape:landscape@db:5432/landscape_ai

# Redis
REDIS_URL=redis://cache:6379/0

# LLM — Groq API (free tier: 30 req/min, 14,400 req/day)
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant

# Embeddings — Local sentence-transformers (no API key needed)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768

# Reranker — Local cross-encoder
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# MinIO Object Store
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Map
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Scraping Schedule
SCRAPE_SCHEDULE_CRON=0 2 * * *

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# Debug
DEBUG=true
